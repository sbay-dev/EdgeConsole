{
  "manifest_version": 3,
  "name": "sbay-dev DevTools",
  "short_name": "sbay-dev",
  "version": "1.0.0",
  "description": "Desktop-grade DevTools for Microsoft Edge on large-screen mobile devices, with native gh copilot cli (MCP) integration.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "devtools_page": "devtools/devtools.html",
  "permissions": [
    "debugger",
    "storage",
    "scripting",
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["panels/host.html", "panels/host.js", "runtime/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
